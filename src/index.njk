---
layout: base.njk
---

{# ── HERO ── #}
<section id="home" class="section hero">
  <div class="hero-avatar">
    <img src="assets/avatar.png" alt="{{ site.name }}" />
  </div>
  <div class="hero-info">
    <h1 class="hero-name">{{ site.name }}</h1>
    <p class="hero-handle">{{ site.handle }}</p>
    <p class="hero-status">
      <span class="status-dot"></span>
      <span data-en="{{ site.status }}" data-pt="{{ site.status_pt }}">{{ site.status }}</span>
    </p>
    <p class="hero-bio">
      <span id="greeting"></span>
      <span data-en="{{ site.bio }}" data-pt="{{ site.bio_pt }}"> {{ site.bio }}</span>
    </p>
    <div class="hero-socials">
      {% if site.github %}
      <a href="{{ site.github }}" target="_blank" rel="noopener" aria-label="GitHub">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.341-3.369-1.341-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.742 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
      </a>
      {% endif %}
      {% if site.linkedin %}
      <a href="{{ site.linkedin }}" target="_blank" rel="noopener" aria-label="LinkedIn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      {% endif %}
      <a href="mailto:{{ site.email }}" aria-label="Email">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
      </a>
    </div>
  </div>
</section>

{# ── ABOUT ── #}
<section id="about" class="section">
  <h2 class="section-title" data-i18n="section.about">About</h2>
  {% for para in site.about %}
  <p class="body-text" data-en="{{ para }}" data-pt="{{ site.about_pt[loop.index0] }}">{{ para }}</p>
  {% endfor %}
</section>

{# ── EDUCATION ── #}
<section id="education" class="section">
  <h2 class="section-title" data-i18n="section.education">Education</h2>
  {% for edu in education %}
  <div class="card">
    <div class="card-header">
      <div>
        <p class="card-title" data-en="{{ edu.degree_en }}" data-pt="{{ edu.degree }}">{{ edu.degree_en }}</p>
        {% if edu.subtitle %}<p class="card-subtitle">{{ edu.subtitle }}</p>{% endif %}
      </div>
      <div class="card-meta">
        <p class="meta-primary">{{ edu.institution }}</p>
        <p class="meta-secondary">{{ edu.date }}</p>
      </div>
    </div>
    {% if edu.honors %}
    <p class="honors">{{ edu.honors }}</p>
    {% endif %}
    {% if edu.coursework.length %}
    <p class="coursework-label" data-i18n="label.coursework">Relevant Coursework</p>
    <div class="tag-row">
      {% for tag in edu.coursework %}
      <span class="tag" data-en="{{ tag.en }}" data-pt="{{ tag.pt }}">{{ tag.en }}</span>
      {% endfor %}
    </div>
    {% endif %}
  </div>
  {% endfor %}
</section>

{# ── EXPERIENCE ── #}
<section id="experience" class="section">
  <h2 class="section-title" data-i18n="section.experience">Experience</h2>
  {% for job in experience %}
  <div class="card">
    <div class="card-header">
      <div>
        <p class="card-title" data-en="{{ job.title_en }}" data-pt="{{ job.title }}">{{ job.title_en }}</p>
        <p class="company-name">{{ job.company }}</p>
      </div>
      <p class="meta-secondary" data-en="{{ job.dates_en }}" data-pt="{{ job.dates }}">{{ job.dates_en }}</p>
    </div>
    <ul class="accordion">
      {% for item in job.achievements %}
      <li class="accordion-item">
        <button class="accordion-trigger" aria-expanded="false">
          <span class="accordion-dot"></span>
          <span class="accordion-name" data-en="{{ item.name_en }}" data-pt="{{ item.name }}">{{ item.name_en }}</span>
          <svg class="accordion-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="accordion-body">
          <p data-en="{{ item.description_en }}" data-pt="{{ item.description }}">{{ item.description_en }}</p>
        </div>
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endfor %}
</section>

{# ── TECH STACK ── #}
<section id="stack" class="section">
  <h2 class="section-title" data-i18n="section.stack">Tech Stack</h2>
  <div class="stack-grid">
    {% for tech in stack %}
    <div class="stack-cell{% if tech.featured %} featured{% endif %}">
      <img
        src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/{{ tech.icon }}"
        alt="{{ tech.name }}"
        width="36"
        height="36"
      />
      <span class="stack-name">{{ tech.name }}</span>
    </div>
    {% endfor %}
  </div>
</section>

{# ── PROJECTS ── #}
<section id="projects" class="section">
  <h2 class="section-title" data-i18n="section.projects">Projects</h2>
  <div class="projects-grid">
    {% for project in projects %}
    <a href="https://{{ project.url }}" target="_blank" rel="noopener" class="project-card">
      <div class="project-header">
        <div class="project-icon">
          {% if project.icon %}
          <img src="{{ project.icon }}" alt="{{ project.name }}" />
          {% else %}
          {{ project.name | truncate(1, true, "") | upper }}
          {% endif %}
        </div>
        <div class="project-title-group">
          <p class="project-name">{{ project.name }}</p>
          <p class="project-url">{{ project.url }}</p>
        </div>
        <span class="project-badge">{{ project.status }}</span>
      </div>
      <p class="project-desc" data-en="{{ project.description }}" data-pt="{{ project.description_pt }}">{{ project.description }}</p>
      <div class="tag-row">
        {% for tag in project.tags %}
        <span class="tag">{{ tag }}</span>
        {% endfor %}
      </div>
    </a>
    {% endfor %}
  </div>
</section>
